{
  "name": "reels-factory",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace=@reels-factory/web",
    "worker": "npm run start --workspace=@reels-factory/worker",
    "test:ffmpeg": "tsx apps/worker/scripts/test-ffmpeg-render.ts",
    "build": "npm run build --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "db:generate": "npm run db:generate --workspace=@reels-factory/web",
    "db:push": "npm run db:push --workspace=@reels-factory/web",
    "db:migrate-v2": "prisma db execute --file=./prisma/migrations/add_product_intel.sql --schema=./prisma/schema.prisma",
    "db:studio": "npm run db:studio --workspace=@reels-factory/web"
  },
  "engines": {
    "node": ">=20"
  }
}
