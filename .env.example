# Database
DATABASE_URL="postgresql://reels:reels@localhost:5432/reels_factory"

# Redis
REDIS_URL="redis://localhost:6379"

# OpenAI (этап 3: сценарии через gpt-4o; без ключа — mock)
OPENAI_API_KEY="sk-..."
# OPENAI_MODEL="gpt-4o"

# S3 / MinIO (local) or Cloudflare R2 (production) — see R2_SETUP.md
S3_ENDPOINT="http://localhost:9000"
S3_REGION="us-east-1"
S3_ACCESS_KEY="minioadmin"
S3_SECRET_KEY="minioadmin"
S3_BUCKET="reels-factory"
S3_PUBLIC_URL="http://localhost:9000/reels-factory"
# Worker only (Docker on Railway):
# REMOTION_CHROME_EXECUTABLE="/usr/bin/chromium"

# Stripe
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_PRICE_BASIC="price_..."
STRIPE_PRICE_PREMIUM="price_..."

# Auth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-a-random-secret-here"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
SKIP_PAYMENT="true"
# Queue: postgres (default, uses Neon — no Upstash quota) or redis
QUEUE_MODE="postgres"
# Playwright: auto on Railway worker; set true locally for JS-heavy sites
PLAYWRIGHT_PARSER="false"
# Tavily — ОБЯЗАТЕЛЕН на Vercel production (маркетплейсы, отзывы, extract страниц)
# Режимы: api_key (рекомендуется) или keyless (по умолчанию без ключа, лимиты ниже)
# Ключ: https://app.tavily.com → scripts/sync-vercel-tavily.ps1
# TAVILY_API_KEY="tvly-..."
# НЕ ставьте TAVILY_KEYLESS=false без TAVILY_API_KEY — research сломается
MOCK_RENDER="false"
# Worker: skip OpenAI image gen — use product photos from parsed page
# MOCK_SCENE_IMAGES="true"
