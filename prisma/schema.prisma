generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  role          String    @default("user")
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]
  reelJobs      ReelJob[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model ReelJob {
  id              String    @id @default(cuid())
  userId          String?
  user            User?     @relation(fields: [userId], references: [id])
  productUrl      String
  productJson     Json
  reelType        String
  highlights      String[]
  customHighlight String?
  ctaType         String
  ctaValue        String?
  scriptJson        Json?
  productIntelJson  Json?
  sceneImagesJson   Json?
  progressJson      Json?
  status            String    @default("draft")
  videoUrl        String?
  errorMessage    String?
  tier            String    @default("basic")
  templateId      String?
  payments        Payment[]
  pipelineLogs    JobPipelineLog[]
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model JobPipelineLog {
  id        String   @id @default(cuid())
  reelJobId String
  reelJob   ReelJob  @relation(fields: [reelJobId], references: [id], onDelete: Cascade)
  at        DateTime
  text      String   @db.Text
  kind      String?
  meta      Json?

  @@index([reelJobId, at])
}

model SiteSettings {
  id          String   @id @default("default")
  promptsJson Json     @default("{}")
  updatedAt   DateTime @updatedAt
}

model Payment {
  id              String   @id @default(cuid())
  reelJobId       String
  reelJob         ReelJob  @relation(fields: [reelJobId], references: [id], onDelete: Cascade)
  stripeSessionId String?  @unique
  amount          Int
  currency        String   @default("usd")
  status          String   @default("pending")
  createdAt       DateTime @default(now())
}
